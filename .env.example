NODE_ENV=development
PORT=4000

DB_HOST=localhost
DB_PORT=3306
DB_HOST_PORT=3307
DB_NAME=student_research
DB_USER=appuser
DB_PASSWORD=password
DB_ROOT_PASSWORD=rootpassword

JWT_SECRET=your-jwt-secret-change-in-production

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

API_ORIGIN=http://localhost:4000
WEB_ORIGIN=http://localhost:3000
CLIENT_URL=http://localhost:3000

# Comma-separated allowed browser origins for CORS in all environments.
# Example: https://app.example.com,https://admin.example.com
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Set for reverse proxy deployments (Railway/NGINX). Accepts true, false, or hop count.
TRUST_PROXY=true

# Optional persistent upload base path (recommended on Railway with volume mount).
# Local development fallback is ./uploads when this is empty.
UPLOAD_PATH=
